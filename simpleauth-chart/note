helm uninstall simpleauth -n simpleauth

kubectl -n simpleauth delete secret ecr-secret --ignore-not-found

kubectl -n simpleauth create secret docker-registry ecr-secret \
  --docker-server=296725355870.dkr.ecr.ap-southeast-1.amazonaws.com \
  --docker-username=AWS \
  --docker-password=$(aws ecr get-login-password --region ap-southeast-1)

helm install simpleauth . -n simpleauth \
  --set ingress.enabled=true \
  --set ingress.className=alb \
  --set ingress.annotations."alb\.ingress\.kubernetes\.io/scheme"=internet-facing \
  --set ingress.annotations."alb\.ingress\.kubernetes\.io/target-type"=ip \
  --set ingress.annotations."alb\.ingress\.kubernetes\.io/listen-ports"='[{"HTTP": 80}]' \
  --set ingress.hosts[0].host="" \
  --set ingress.hosts[0].paths[0].path="/" \
  --set ingress.hosts[0].paths[0].pathType="Prefix" \
  --set ingress.hosts[0].paths[0].serviceName="simpleauth-ui" \
  --set ingress.hosts[0].paths[0].servicePort=80 \
  --set ingress.hosts[0].paths[1].path="/api" \
  --set ingress.hosts[0].paths[1].pathType="Prefix" \
  --set ingress.hosts[0].paths[1].serviceName="simpleauth-api" \
  --set ingress.hosts[0].paths[1].servicePort=80