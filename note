aws eks --region ap-southeast-1 update-kubeconfig --name retail-vti-do2508-de000159-quyen-eksdemo

aws eks create-addon --cluster-name retail-vti-do2508-de000159-quyen-eksdemo --addon-name eks-pod-identity-agent --region ap-southeast-1

aws eks list-addons --cluster-name "retail-vti-do2508-de000159-quyen-eksdemo"

aws eks create-pod-identity-association --cluster-name retail-vti-do2508-de000159-quyen-eksdemo --namespace kube-system --service-account aws-load-balancer-controller --role-arn arn:aws:iam::296725355870:role/AmazonEKS_LBC_Role_retail-vti-do2508-de000159-quyen-eksdemo

aws eks describe-cluster --name retail-vti-do2508-de000159-quyen-eksdemo --query "cluster.resourcesVpcConfig.vpcId" --output text

helm upgrade --install aws-load-balancer-controller eks/aws-load-balancer-controller -n kube-system --set clusterName=retail-vti-do2508-de000159-quyen-eksdemo --set region=ap-southeast-1 --set vpcId=vpc-02b36ba9d7cc9a720 --set serviceAccount.create=true --set serviceAccount.name=aws-load-balancer-controller

aws ecr create-repository --repository-name quyen-simpleauth-api --region ap-southeast-1
aws ecr create-repository --repository-name quyen-simpleauth-ui --region ap-southeast-1

aws ecr get-login-password --region ap-southeast-1 | docker login --username AWS --password-stdin 296725355870.dkr.ecr.ap-southeast-1.amazonaws.com

cd SimpleAuthApi
docker build -t 296725355870.dkr.ecr.ap-southeast-1.amazonaws.com/quyen-simpleauth-api:latest .
docker push 296725355870.dkr.ecr.ap-southeast-1.amazonaws.com/quyen-simpleauth-api:latest

cd ../SimpleAuthUi
docker build -t 296725355870.dkr.ecr.ap-southeast-1.amazonaws.com/quyen-simpleauth-ui:latest .
docker push 296725355870.dkr.ecr.ap-southeast-1.amazonaws.com/quyen-simpleauth-ui:latest

# Pull image Bitnami PostgreSQL
docker pull bitnami/postgresql:latest

docker tag bitnami/postgresql:latest 296725355870.dkr.ecr.ap-southeast-1.amazonaws.com/postgresql:latest

aws ecr create-repository \
  --repository-name postgresql \
  --region ap-southeast-1

docker push 296725355870.dkr.ecr.ap-southeast-1.amazonaws.com/postgresql:latest
