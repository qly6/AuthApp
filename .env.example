# PostgreSQL
POSTGRES_USER=authuser
POSTGRES_PASSWORD=SuperSecretPassword123!
POSTGRES_DB=authdb

# JWT (use a strong random key)
JWT_KEY=your-very-long-and-secure-random-key-at-least-32-chars
JWT_ISSUER=https://auth.yourdomain.com
JWT_AUDIENCE=https://api.yourdomain.com

# FIDO2 / WebAuthn
FIDO_DOMAIN=localhost
FIDO_ORIGIN=http://localhost:4200